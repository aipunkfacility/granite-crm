# Granite CRM Configuration

# ── Секреты и учётные данные ──

# CRM admin
GRANITE_ADMIN_PASSWORD=

# API auth (пустой = dev-mode, auth отключён)
GRANITE_API_KEY=

# ── SMTP (обязательно для рассылки) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465                          # 465 = SMTP_SSL, 587 = SMTP+STARTTLS
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password            # Gmail App Password (16 символов), НЕ обычный пароль

# ── IMAP (bounce + reply; использует SMTP_USER/SMTP_PASS) ──
# IMAP_HOST/IMAP_PORT не нужны — дефолты imap.gmail.com:993 совпадают с SMTP

# ── Telegram API (для tg_finder) ──
# TELEGRAM_API_ID=your_api_id
# TELEGRAM_API_HASH=your_api_hash

# ── Telescan API (опционально) ──
# TELESCAN_API_KEY=your_telescan_key

# ── Отправитель ──
FROM_NAME=Александр

# ── API / Deploy ──
CORS_ORIGINS=http://localhost:3000,http://localhost:5173    # Разделить запятыми
BASE_URL=https://your-tunnel-url.example.com                # Cloudflare Tunnel или аналогичный

# ── Примечание ──
# DATABASE_URL, EMAIL_DELAY_MIN/MAX, EMAIL_DAILY_LIMIT, MAX_SENDS_PER_RUN
# перенесены в config.yaml (секция email + database).
# IMAP_HOST/IMAP_PORT убраны — дефолты совпадают с Gmail.
