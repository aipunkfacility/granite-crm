# .env.example — Granite CRM Email Campaign
# Скопируйте в .env и заполните значениями

# ── SMTP (обязательно для рассылки) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465                          # 465 = SMTP_SSL (implicit TLS), 587 = SMTP+STARTTLS
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password            # Gmail App Password (16 символов), НЕ обычный пароль

# ── IMAP (обязательно для bounce + reply) ──
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
# SMTP_USER и SMTP_PASS используются для IMAP тоже

# ── API ──
GRANITE_API_KEY=                       # Оставить пустым для dev-mode (auth отключён)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173    # Разделить запятыми

# ── Публичный URL (для tracking + unsubscribe) ──
BASE_URL=https://your-tunnel-url.example.com    # Cloudflare Tunnel или аналогичный

# ── Отправка ──
FROM_NAME=Александр
EMAIL_DELAY_MIN=45                     # минимальная задержка между письмами (секунд)
EMAIL_DELAY_MAX=120                    # максимальная задержка между письмами (секунд)
EMAIL_DAILY_LIMIT=50                   # максимум писем в сутки

# ── Опционально ──
# DGIS_API_KEY=your-2gis-api-key
